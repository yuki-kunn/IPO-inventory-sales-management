rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // === セキュリティポリシー ===
    // クライアント側からの直接アクセスを完全に禁止
    // すべての操作はサーバー側API（Firebase Admin SDK）経由でのみ実行
    // これにより、認証機能なしでもセキュリティを担保

    // すべてのコレクションへのアクセスを拒否
    match /{document=**} {
      allow read, write: if false;
    }

    // 注意: Firebase Admin SDK経由のアクセスはこのルールの対象外
    // Admin SDKは全権限を持つため、サーバー側で適切にアクセス制御を行う必要がある
  }
}

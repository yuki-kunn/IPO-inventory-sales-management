{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/calendar/?(?:/__data.json)?$",
			"dest": "/calendar"
		},
		{
			"src": "^/calendar/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/calendar/[date]"
		},
		{
			"src": "^/ingredients/?(?:/__data.json)?$",
			"dest": "/ingredients"
		},
		{
			"src": "^/recipes/?(?:/__data.json)?$",
			"dest": "/recipes"
		},
		{
			"src": "^/unregistered/?(?:/__data.json)?$",
			"dest": "/unregistered"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}
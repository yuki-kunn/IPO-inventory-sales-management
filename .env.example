# Firebase Configuration (Client-side - 読み取り専用)
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (Server-side only - 書き込み権限あり)
# プロジェクトIDを設定（サービスアカウントキー不要の場合）
FIREBASE_ADMIN_PROJECT_ID=your_project_id
# または、サービスアカウントキーのJSONをBase64エンコードして設定
# FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY=base64_encoded_service_account_json

# Weather API (WeatherAPI.com)
WEATHER_API_KEY=your_weather_api_key_here

# Notion API Configuration
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_main_notion_database_id_here
NOTION_DATABASE_ID_IMPORT=your_import_notion_database_id_here
